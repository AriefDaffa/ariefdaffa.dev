---
import PageLayout from '../layouts/PageLayout.astro';

const description = 'Career history and work experience of Arief Daffa, frontend developer based in Bekasi, Indonesia.';

const experiences = [
  {
    period: '2025 – Present',
    start: 'Dec 2025',
    role: 'Frontend Developer',
    company: 'CODE.ID',
    location: 'Jakarta',
    type: 'Contract',
    current: true,
    description: 'Contract role building production web interfaces in a hybrid setup. Shipping features across multiple client products with a focus on performance and maintainability.',
    highlights: [
      'Building production-grade interfaces for client products',
      'Working in a hybrid team across multiple concurrent projects',
      'Frontend architecture decisions and code reviews',
    ],
    stack: ['React', 'TypeScript', 'Next.js', 'TailwindCSS'],
  },
  {
    period: '2023 – 2025',
    start: 'Aug 2023',
    role: 'Frontend Web Developer',
    company: 'PT FAN Integrasi Teknologi',
    location: 'Indonesia',
    type: 'Full-time',
    current: false,
    description: 'Built and maintained React features across production applications. Refactored legacy code, improved app stability, and introduced better patterns across the frontend codebase.',
    highlights: [
      'Rebuilt core UI components used across 3+ products',
      'Reduced technical debt through systematic refactoring',
      'Improved app stability and load performance',
    ],
    stack: ['React', 'TypeScript', 'Redux', 'REST API'],
  },
  {
    period: '2022',
    start: 'May 2022',
    role: 'Software Engineer Intern',
    company: 'Tokopedia Web Platform',
    location: 'Jakarta',
    type: 'Internship',
    current: false,
    description: "Worked on search components within Tokopedia's web platform team. Contributed to debugging, unit testing, and frontend performance improvements at scale.",
    highlights: [
      'Contributed to search UI components used by millions of users',
      'Wrote unit tests and improved test coverage',
      'Optimised render performance on high-traffic pages',
    ],
    stack: ['React', 'JavaScript', 'Jest', 'GraphQL'],
  },
  {
    period: '2022',
    start: 'Jan 2022',
    role: 'Lead Frontend Developer',
    company: 'KawanBantu',
    location: 'Indonesia',
    type: 'Part-time',
    current: false,
    description: 'Led the frontend workflow for a user-facing application. Introduced tooling standards, defined component architecture, and maintained the product through active development.',
    highlights: [
      'Led a small frontend team and defined coding standards',
      'Introduced linting, formatting, and CI tooling',
      'Owned the component architecture end-to-end',
    ],
    stack: ['React', 'JavaScript', 'CSS Modules'],
  },
  {
    period: '2021',
    start: 'Mar 2021',
    role: 'Frontend Department',
    company: 'BCC Faculty of Computer Science',
    location: 'Brawijaya University',
    type: 'Organisation',
    current: false,
    description: 'Member of the frontend department at BCC, a software engineering community at Brawijaya University. Grew through collaborative engineering practice, workshops, and real-world projects.',
    highlights: [
      'Participated in community-led engineering workshops',
      'Collaborated on internal tooling and web projects',
      'Mentored by senior students, later mentored juniors',
    ],
    stack: ['HTML', 'CSS', 'JavaScript', 'React'],
  },
];

const stats = [
  { value: '4+', label: 'Years building' },
  { value: '4', label: 'Companies' },
  { value: '10+', label: 'Projects shipped' },
  { value: '1', label: 'Big tech internship' },
];
---

<PageLayout
  title="Experience - Arief Daffa"
  description={description}
  pathname="/experience/"
  marqueeItems={['Work', 'Build', 'Ship', 'Grow', 'Repeat']}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    name: 'Experience - Arief Daffa',
    description,
    url: 'https://ariefdaffa.dev/experience/',
  }}
>

  <!-- ── Hero ── -->
  <section class="section exp-hero">
    <div class="container">
      <p class="page-kicker">Experience</p>
      <div class="exp-hero-grid">
        <h1 class="exp-hero-title">Work<br/>history.</h1>
        <div class="exp-hero-right">
          <div class="exp-current-card">
            <span class="exp-current-badge">Currently</span>
            <p class="exp-current-company">CODE.ID</p>
            <p class="exp-current-role">Frontend Developer</p>
            <p class="exp-current-since">Since Dec 2025 · Jakarta</p>
          </div>
          <p class="exp-hero-summary">
            Frontend-focused roles across product companies, startups, and internships.
            Building interfaces from the ground up since 2021.
          </p>
        </div>
      </div>

      <!-- Stats strip -->
      <div class="exp-stats">
        {stats.map(s => (
          <div class="exp-stat">
            <span class="exp-stat-value">{s.value}</span>
            <span class="exp-stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Timeline ── -->
  <section class="section exp-timeline-section">
    <div class="container">
      <div class="exp-timeline" aria-label="Career timeline">
        {experiences.map((exp) => (
          <article class={`exp-item${exp.current ? ' exp-item--current' : ''} js-exp-reveal`}>
            <div class="exp-item-spine" aria-hidden="true">
              <span class="exp-item-dot"></span>
            </div>
            <div class="exp-item-body">
              <header class="exp-item-header">
                <div class="exp-item-meta">
                  <span class="exp-type-pill">{exp.type}</span>
                  <span class="exp-date">{exp.start}</span>
                </div>
                <h2 class="exp-role">{exp.role}</h2>
                <p class="exp-company">{exp.company} <span class="exp-location">· {exp.location}</span></p>
              </header>
              <p class="exp-description">{exp.description}</p>
              <ul class="exp-highlights">
                {exp.highlights.map(h => (
                  <li>{h}</li>
                ))}
              </ul>
              <div class="exp-stack">
                {exp.stack.map(tech => (
                  <span class="exp-tech">{tech}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</PageLayout>

<script>
  import { gsap } from 'https://cdn.skypack.dev/gsap';
  import { ScrollTrigger } from 'https://cdn.skypack.dev/gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const items = document.querySelectorAll('.js-exp-reveal');
  items.forEach((el, i) => {
    gsap.fromTo(
      el,
      { opacity: 0, y: 48 },
      {
        opacity: 1,
        y: 0,
        duration: 0.72,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 88%',
        },
      }
    );
  });

  // Animate stats on load
  gsap.fromTo(
    '.exp-stat',
    { opacity: 0, y: 24 },
    { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out', stagger: 0.1, delay: 0.3 }
  );
</script>
