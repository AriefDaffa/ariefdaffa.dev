---
import HomeLayout from '../layouts/HomeLayout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getCollection } from 'astro:content';
import { formatDate, readingTime } from '../utils/format';

// Pull latest 3 blog posts
const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Pull top 6 projects: featured first, then by year
const featuredProjects = (await getCollection('projects'))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return Number(b.data.featured) - Number(a.data.featured);
    return b.data.year - a.data.year;
  })
  .slice(0, 6);

// Card size pattern matches original design: small, small, feature, wide, small, small
const cardSizes = ['small', 'small', 'feature', 'wide', 'small', 'small'];
---

<HomeLayout
  title="Arief Daffa - Web Developer"
  description="Arief Daffa is a web developer building polished, performant interfaces for products, portfolios, and digital tools."
  pathname="/"
>
<main id="top" class="site-shell">
  <section class="section hero">
    <div class="container hero-showcase">
      <div
        class="hero-panel"
        aria-label="Arief Daffa portfolio introduction"
      >
        <img
          class="hero-bg"
          src="https://images.unsplash.com/photo-1498050108023-c5249f4df0852?auto=format&fit=crop&w=2400&q=85"
          alt="Laptop workspace with code editor"
          loading="eager"
          decoding="async"
          width="2400"
          height="1600"
        />

        <div class="hero-center">
          <p>
            Every web interface I build begins with structure, evolves
            through design, and ships as a fast, focused experience.
          </p>
        </div>

        <h1 class="hero-title">Arief Daffa</h1>
      </div>

      <div class="social-grid" aria-label="Social profiles">
        <a class="social-card" href="https://github.com/AriefDaffa" target="_blank" rel="noreferrer">
          <span class="social-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M12 .5A11.5 11.5 0 0 0 8.36 22.9c.58.1.79-.25.79-.56v-2.02c-3.22.7-3.9-1.38-3.9-1.38-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.7.08-.7 1.17.08 1.79 1.2 1.79 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.75.4-1.27.74-1.56-2.57-.29-5.27-1.28-5.27-5.72 0-1.27.45-2.3 1.2-3.11-.12-.3-.52-1.48.12-3.08 0 0 .98-.31 3.2 1.19a11.1 11.1 0 0 1 5.82 0c2.22-1.5 3.2-1.19 3.2-1.19.64 1.6.24 2.78.12 3.08.75.82 1.2 1.85 1.2 3.11 0 4.45-2.71 5.43-5.3 5.72.42.36.8 1.08.8 2.18v3.23c0 .31.2.67.8.56A11.5 11.5 0 0 0 12 .5Z"></path></svg>
          </span>
          <span class="sr-only">GitHub</span>
        </a>
        <a class="social-card" href="https://instagram.com/ariefdaffa" target="_blank" rel="noreferrer">
          <span class="social-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M7.8 2h8.4A5.8 5.8 0 0 1 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8A5.8 5.8 0 0 1 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2Zm0 2A3.8 3.8 0 0 0 4 7.8v8.4A3.8 3.8 0 0 0 7.8 20h8.4a3.8 3.8 0 0 0 3.8-3.8V7.8A3.8 3.8 0 0 0 16.2 4H7.8Zm8.85 2.05a1.3 1.3 0 1 1 0 2.6 1.3 1.3 0 0 1 0-2.6ZM12 7.2a4.8 4.8 0 1 1 0 9.6 4.8 4.8 0 0 1 0-9.6Zm0 2a2.8 2.8 0 1 0 0 5.6 2.8 2.8 0 0 0 0-5.6Z"></path></svg>
          </span>
          <span class="sr-only">Instagram</span>
        </a>
        <a class="social-card" href="https://www.linkedin.com/in/arief-daffa" target="_blank" rel="noreferrer">
          <span class="social-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5.001 2.5 2.5 0 0 1 0-5ZM3 9.75h4v11.5H3V9.75Zm6.25 0h3.84v1.57h.06c.53-1 1.84-2.06 3.78-2.06 4.04 0 4.79 2.66 4.79 6.12v5.87h-4v-5.2c0-1.24-.02-2.83-1.73-2.83-1.73 0-1.99 1.35-1.99 2.74v5.29h-4V9.75Z"></path></svg>
          </span>
          <span class="sr-only">LinkedIn</span>
        </a>
        <a class="social-card" href="mailto:hello@ariefdaffa.dev">
          <span class="social-icon" aria-hidden="true">@</span>
          <span class="sr-only">Email</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section skill-showcase" id="services">
    <div class="container">
      <div class="skills-layout">
        <div class="skills-intro">
          <p class="section-eyebrow">Skills</p>
          <h2>Tools I use to ship carefully.</h2>
          <p>
            A practical stack for building responsive product surfaces,
            maintainable components, and web apps that stay fast under real
            usage.
          </p>
        </div>

        <div class="skill-rows">
          <article class="skill-row">
            <h3>Frontend engineering</h3>
            <div>
              <p>Component architecture, interaction details, accessibility, and performance-sensitive front ends.</p>
              <div class="skill-list">
                <span>React</span><span>Next.js</span><span>Astro</span><span>TypeScript</span><span>JavaScript</span>
              </div>
            </div>
          </article>
          <article class="skill-row">
            <h3>Interface styling</h3>
            <div>
              <p>Detailed layouts, reusable design tokens, and expressive motion without sacrificing clarity.</p>
              <div class="skill-list">
                <span>TailwindCSS</span><span>CSS</span><span>GSAP</span>
              </div>
            </div>
          </article>
          <article class="skill-row">
            <h3>Backend basics</h3>
            <div>
              <p>Enough server-side experience to collaborate cleanly across product boundaries.</p>
              <div class="skill-list">
                <span>Laravel</span><span>Node.js</span><span>Elysia.js</span>
              </div>
            </div>
          </article>
          <article class="skill-row">
            <h3>Product workflow</h3>
            <div>
              <p>Git workflows, API integration, testing habits, and turning design references into working UI.</p>
              <div class="skill-list">
                <span>Git</span><span>REST APIs</span><span>Testing</span><span>Web Vitals</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="section dark-band">
    <div class="container">
      <p class="manifesto js-manifesto">
        Five years building interfaces. Still obsessed with the details. Still learning something new every week.
      </p>
    </div>
  </section>

  <section class="section timeline-section" id="timeline">
    <div class="container">
      <div class="timeline-head">
        <p class="section-eyebrow">History</p>
        <h2>Experiences</h2>
      </div>
      <div class="timeline" aria-label="Career timeline">
        <article class="timeline-item">
          <div class="timeline-content left">
            <h3>Frontend Developer</h3>
            <p>CODE.ID, Jakarta. Contract role building production web interfaces in a hybrid setup.</p>
          </div>
          <div class="timeline-date">
            <span class="timeline-pill">12 - 25</span>
            <span class="timeline-line" aria-hidden="true"></span>
          </div>
        </article>
        <article class="timeline-item">
          <div class="timeline-date">
            <span class="timeline-pill">08 - 23</span>
            <span class="timeline-line" aria-hidden="true"></span>
          </div>
          <div class="timeline-content right">
            <h3>Frontend Web Developer</h3>
            <p>PT FAN Integrasi Teknologi. Built React features, refactored production code, and improved app stability.</p>
          </div>
        </article>
        <article class="timeline-item">
          <div class="timeline-content left">
            <h3>Software Engineer Intern</h3>
            <p>Tokopedia Web Platform. Worked on search components, debugging, tests, and performance improvement.</p>
          </div>
          <div class="timeline-date">
            <span class="timeline-pill">05 - 22</span>
            <span class="timeline-line" aria-hidden="true"></span>
          </div>
        </article>
        <article class="timeline-item">
          <div class="timeline-date">
            <span class="timeline-pill">01 - 22</span>
            <span class="timeline-line" aria-hidden="true"></span>
          </div>
          <div class="timeline-content right">
            <h3>Lead Frontend Developer</h3>
            <p>KawanBantu. Led frontend workflow, introduced tooling, and maintained a user-facing application.</p>
          </div>
        </article>
        <article class="timeline-item">
          <div class="timeline-content left">
            <h3>Frontend Department</h3>
            <p>BCC Faculty of Computer Science, Brawijaya University. Grew through community engineering practice.</p>
          </div>
          <div class="timeline-date">
            <span class="timeline-pill">03 - 21</span>
            <span class="timeline-line" aria-hidden="true"></span>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section portfolio-section" id="work">
    <div class="container">
      <div class="portfolio-head">
        <div>
          <p class="section-eyebrow">Portfolio</p>
          <h2>My projects.</h2>
        </div>
        <a class="portfolio-button" href="/projects/">
          See all <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
      <div class="portfolio-grid" aria-label="Featured portfolio projects">
        {
          featuredProjects.map((project, index) => (
            <a
              class={`portfolio-card ${cardSizes[index] ?? 'small'} js-scale-fade`}
              href={`/projects/${project.id}/`}
              aria-label={`Open ${project.data.title} project detail`}
            >
              <img
                src={project.data.image}
                alt={`${project.data.title} project preview`}
                loading="lazy"
                decoding="async"
                width="800"
                height="600"
              />
              <div class="portfolio-copy">
                <h3>{project.data.title}</h3>
                <p>{project.data.year} &middot; {project.data.technologies.slice(0, 3).join(', ')}</p>
              </div>
              <span class="portfolio-arrow" aria-hidden="true">&rarr;</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      <span>Astro</span><span>React</span><span>TypeScript</span><span>Tailwind</span>
      <span>GSAP</span><span>Accessibility</span><span>Performance</span><span>Design Systems</span>
      <span>Astro</span><span>React</span><span>TypeScript</span><span>Tailwind</span>
      <span>GSAP</span><span>Accessibility</span><span>Performance</span><span>Design Systems</span>
    </div>
  </div>

  <section class="section blog-section" id="blog">
    <div class="container">
      <div class="portfolio-head">
        <div>
          <p class="section-eyebrow">Blog</p>
          <h2>Latest writing.</h2>
        </div>
        <a class="portfolio-button" href="/blog/">
          See all <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
      <div class="blog-grid" aria-label="Latest blog posts">
        {
          latestPosts.map((post) => (
            <article class="blog-card">
              <div class="blog-meta">
                <span>{formatDate(post.data.pubDate)}</span>
                <span>{readingTime(post.body)}</span>
              </div>
              <div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
              <a class="blog-card-footer" href={`/blog/${post.id}/`}>
                Read article <span aria-hidden="true">&rarr;</span>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section footer-section" id="contact">
    <div class="container">
      <SiteFooter />
    </div>
  </section>
</main>
</HomeLayout>
