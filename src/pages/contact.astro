---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import ContactForm from '../components/contact/ContactForm';
import { siteConfig } from '../lib/config';
---

<BaseLayout
  title="Contact"
  description="Get in touch with me for collaborations, opportunities, or just to say hello."
>
  <PageHeader
    title="Get in Touch"
    description="Have a project in mind, a question, or just want to connect? I'd love to hear from you."
  />

  <section class="py-16 md:py-24">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 max-w-5xl mx-auto">
        <!-- Contact info -->
        <div class="lg:col-span-2 space-y-8">
          <div class="glass rounded-2xl p-6 space-y-6">
            <h2 class="text-white font-semibold text-lg">Let's connect</h2>
            <p class="text-midnight-200 text-sm leading-relaxed">
              I'm always interested in hearing about new projects and opportunities. Whether you have a question or just want to say hi, feel free to reach out.
            </p>

            <div class="h-px bg-glass-border"></div>

            <!-- Contact links -->
            <div class="space-y-4">
              <a
                href={`mailto:${siteConfig.email}`}
                class="flex items-center gap-3 text-midnight-200 hover:text-violet-400 transition-colors group"
              >
                <div class="w-10 h-10 rounded-xl glass flex items-center justify-center group-hover:bg-violet-500/10 transition-colors">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-midnight-400">Email</p>
                  <p class="text-sm">{siteConfig.email}</p>
                </div>
              </a>

              <a
                href={siteConfig.links.github}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-midnight-200 hover:text-violet-400 transition-colors group"
              >
                <div class="w-10 h-10 rounded-xl glass flex items-center justify-center group-hover:bg-violet-500/10 transition-colors">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                </div>
                <div>
                  <p class="text-xs text-midnight-400">GitHub</p>
                  <p class="text-sm">@ariefdaffa</p>
                </div>
              </a>

              <a
                href={siteConfig.links.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-midnight-200 hover:text-violet-400 transition-colors group"
              >
                <div class="w-10 h-10 rounded-xl glass flex items-center justify-center group-hover:bg-violet-500/10 transition-colors">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </div>
                <div>
                  <p class="text-xs text-midnight-400">LinkedIn</p>
                  <p class="text-sm">Arief Daffa</p>
                </div>
              </a>

              <a
                href={siteConfig.links.twitter}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-midnight-200 hover:text-violet-400 transition-colors group"
              >
                <div class="w-10 h-10 rounded-xl glass flex items-center justify-center group-hover:bg-violet-500/10 transition-colors">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </div>
                <div>
                  <p class="text-xs text-midnight-400">Twitter / X</p>
                  <p class="text-sm">@ariefdaffa</p>
                </div>
              </a>
            </div>
          </div>
        </div>

        <!-- Contact form -->
        <div class="lg:col-span-3">
          <div class="glass rounded-2xl p-6 md:p-8">
            <h2 class="text-white font-semibold text-lg mb-6">Send a message</h2>
            <ContactForm client:visible />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
