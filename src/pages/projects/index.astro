---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import ProjectCard from '../../components/projects/ProjectCard.astro';
import GitHubRepos from '../../components/projects/GitHubRepos';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import { fetchGitHubRepos } from '../../services/github';
import projectsData from '../../data/projects.json';

const repos = await fetchGitHubRepos({ username: 'AriefDaffa', perPage: 12 });
---

<BaseLayout
  title="Projects"
  description="Explore my portfolio of projects, from full-stack web applications to open-source developer tools and creative experiments."
>
  <PageHeader
    title="Projects"
    description="A curated collection of projects I've built, contributed to, and am proud of."
  />

  <!-- Personal Projects -->
  <section class="py-16 md:py-24">
    <div class="section-container">
      <SectionHeader
        label="Portfolio"
        title="Featured Work"
        description="Hand-picked projects that showcase my skills and passion for building great software."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projectsData.map((project) => (
          <ProjectCard
            title={project.title}
            slug={project.slug}
            description={project.description}
            technologies={project.technologies}
            githubUrl={project.githubUrl}
            liveUrl={project.liveUrl}
            image={project.image}
            featured={false}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- GitHub Repositories -->
  <section class="py-16 md:py-24">
    <div class="section-container">
      <SectionHeader
        label="Open Source"
        title="GitHub Repositories"
        description="My latest open-source work, fetched directly from GitHub."
      />

      <GitHubRepos repos={repos} client:visible />

      <div class="text-center mt-12">
        <a
          href="https://github.com/AriefDaffa"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl glass text-midnight-200 hover:text-heading text-sm font-medium transition-all duration-300 hover:bg-glass-active"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View all on GitHub
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
