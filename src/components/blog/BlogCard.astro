---
import { formatDate, calculateReadingTime } from '../../lib/utils';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  body?: string;
  featured?: boolean;
  heroImage?: string;
}

const { title, description, pubDate, tags, slug, body = '', featured = false, heroImage } = Astro.props;
const readingTime = calculateReadingTime(body);
---

<a
  href={`/blog/${slug}`}
  class:list={[
    'group block rounded-2xl overflow-hidden transition-all duration-500',
    'glass hover:bg-glass-hover hover:-translate-y-1',
    featured ? 'md:col-span-2' : '',
  ]}
>
  <!-- Hero image -->
  {heroImage && (
    <div class="h-40 overflow-hidden">
      <img
        src={heroImage}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
        loading="lazy"
      />
    </div>
  )}

  <!-- Top accent (only if no hero image) -->
  {!heroImage && (
    <div class="h-1 w-full bg-gradient-to-r from-violet-500 via-neon-blue to-neon-cyan opacity-60 group-hover:opacity-100 transition-opacity duration-300"></div>
  )}

  <div class="p-6 space-y-4">
    <!-- Meta -->
    <div class="flex items-center gap-3 text-xs text-midnight-400">
      <time datetime={pubDate.toISOString()}>
        {formatDate(pubDate)}
      </time>
      <span>·</span>
      <span>{readingTime} min read</span>
      {featured && (
        <>
          <span>·</span>
          <span class="text-violet-400 font-medium">Featured</span>
        </>
      )}
    </div>

    <!-- Title -->
    <h3 class="text-heading font-semibold text-lg leading-snug group-hover:text-violet-400 transition-colors duration-300">
      {title}
    </h3>

    <!-- Description -->
    <p class="text-midnight-200 text-sm leading-relaxed line-clamp-2">
      {description}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 pt-1">
      {tags.slice(0, 3).map((tag) => (
        <span class="px-2 py-0.5 rounded-md bg-midnight-800 text-midnight-300 text-xs font-mono">
          #{tag}
        </span>
      ))}
    </div>

    <!-- Read more arrow -->
    <div class="flex items-center gap-2 text-violet-400 text-sm font-medium pt-2">
      <span>Read article</span>
      <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
      </svg>
    </div>
  </div>
</a>
