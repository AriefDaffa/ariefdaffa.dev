---
interface Props {
  label?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { label, title, description, align = 'center' } = Astro.props;
---

<div class:list={[
  'mb-12 md:mb-16',
  align === 'center' ? 'text-center' : 'text-left',
]}>
  {label && (
    <span class="inline-block px-3 py-1 rounded-full bg-violet-500/10 border border-violet-500/20 text-violet-400 text-xs font-mono uppercase tracking-wider mb-4">
      {label}
    </span>
  )}
  <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white tracking-tight">
    {title}
  </h2>
  {description && (
    <p class:list={[
      'mt-4 text-midnight-200 text-lg max-w-2xl leading-relaxed',
      align === 'center' ? 'mx-auto' : '',
    ]}>
      {description}
    </p>
  )}
</div>
