---
interface Props {
  title: string;
  description?: string;
  backHref?: string;
  backLabel?: string;
}

const { title, description, backHref, backLabel } = Astro.props;
---

<section class="relative pt-32 pb-16 md:pt-40 md:pb-20 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0">
    <div class="absolute top-0 left-1/3 w-[600px] h-[400px] bg-violet-500/5 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-0 right-1/4 w-[400px] h-[300px] bg-neon-blue/5 blur-[100px] rounded-full"></div>
  </div>

  <div class="section-container relative z-10">
    {backHref && (
      <a
        href={backHref}
        class="inline-flex items-center gap-2 text-midnight-300 hover:text-violet-400 transition-colors text-sm mb-8"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        {backLabel || 'Back'}
      </a>
    )}

    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-white tracking-tight">
      {title}
    </h1>
    {description && (
      <p class="mt-4 text-midnight-200 text-lg max-w-2xl leading-relaxed">
        {description}
      </p>
    )}
  </div>

  <!-- Bottom divider -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-glass-border to-transparent"></div>
</section>
