---
import { siteConfig } from '../../lib/config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  tags?: string[];
  canonicalUrl?: string;
  noindex?: boolean;
}

const {
  title,
  description = siteConfig.description,
  image = siteConfig.ogImage,
  type = 'website',
  publishedTime,
  tags,
  canonicalUrl,
  noindex = false,
} = Astro.props;

const pageTitle = title ? `${title} — ${siteConfig.name}` : siteConfig.title;
const resolvedImage = new URL(image, siteConfig.url).toString();
const resolvedCanonical = canonicalUrl || new URL(Astro.url.pathname, siteConfig.url).toString();
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Primary Meta Tags -->
<title>{pageTitle}</title>
<meta name="title" content={pageTitle} />
<meta name="description" content={description} />
<meta name="author" content={siteConfig.author} />
{tags && <meta name="keywords" content={tags.join(', ')} />}
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Canonical -->
<link rel="canonical" href={resolvedCanonical} />

<!-- Favicons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />

<!-- OpenGraph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={resolvedCanonical} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedImage} />
<meta property="og:site_name" content={siteConfig.name} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={resolvedCanonical} />
<meta property="twitter:title" content={pageTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={resolvedImage} />

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title={siteConfig.name} href="/rss.xml" />

<!-- Schema.org -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": type === 'article' ? 'Article' : 'WebSite',
  "name": pageTitle,
  "description": description,
  "url": resolvedCanonical,
  "image": resolvedImage,
  ...(type === 'article' && publishedTime
    ? {
        "datePublished": publishedTime,
        "author": {
          "@type": "Person",
          "name": siteConfig.author,
          "url": siteConfig.url,
        },
      }
    : {
        "author": {
          "@type": "Person",
          "name": siteConfig.author,
        },
      }),
})} />

<!-- Theme color -->
<meta name="theme-color" content="#05060f" />
