---
import HeroScene from './HeroScene';
import { siteConfig } from '../../lib/config';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden" id="hero">
  <!-- Three.js Canvas -->
  <div class="absolute inset-0">
    <HeroScene client:load />
  </div>

  <!-- Gradient overlays for depth -->
  <div class="absolute inset-0 bg-gradient-to-b from-midnight-950/30 via-transparent to-midnight-950 pointer-events-none"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-midnight-950/50 via-transparent to-midnight-950/50 pointer-events-none"></div>

  <!-- Bottom glow -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-violet-500/10 blur-[120px] rounded-full pointer-events-none"></div>

  <!-- Content -->
  <div class="relative z-10 section-container text-center">
    <div class="max-w-4xl mx-auto space-y-8">
      <!-- Status badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass text-sm animate-fade-in">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        <span class="text-midnight-200">Available for opportunities</span>
      </div>

      <!-- Main heading -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight animate-slide-up">
        <span class="text-white">Hi, I'm </span>
        <span class="gradient-text">{siteConfig.name}</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl md:text-2xl text-midnight-200 max-w-2xl mx-auto leading-relaxed animate-slide-up" style="animation-delay: 0.15s;">
        Web Developer crafting
        <span class="text-violet-400"> captivating web experiences</span>
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center pt-4 animate-slide-up" style="animation-delay: 0.3s;">
        <a
          href="/projects"
          class="group relative px-8 py-3.5 rounded-xl bg-gradient-to-r from-violet-600 to-violet-500 text-white font-semibold text-sm transition-all duration-300 hover:shadow-lg hover:shadow-violet-500/25 hover:-translate-y-0.5"
        >
          View My Work
          <span class="inline-block ml-2 transition-transform group-hover:translate-x-1">&rarr;</span>
        </a>
        <a
          href="/contact"
          class="px-8 py-3.5 rounded-xl glass text-white font-semibold text-sm transition-all duration-300 hover:bg-white/10 hover:-translate-y-0.5 gradient-border"
        >
          Get in Touch
        </a>
      </div>

    </div>
  </div>

  <!-- Scroll indicator (positioned relative to section) -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce hidden md:block z-10">
    <div class="w-6 h-10 rounded-full border-2 border-midnight-500 flex justify-center pt-2">
      <div class="w-1 h-2 bg-violet-400 rounded-full animate-pulse"></div>
    </div>
  </div>
</section>
